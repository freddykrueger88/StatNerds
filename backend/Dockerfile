FROM node:20-slim

# OpenSSL für Prisma Schema Engine
RUN apt-get update -y && apt-get install -y openssl ca-certificates && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY package.json .
RUN npm install
COPY prisma ./prisma
RUN npx prisma generate
COPY src ./src
EXPOSE 8000
CMD ["sh", "-c", "npx prisma migrate deploy && npm start"]
